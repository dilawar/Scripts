[column]
    ui = auto
[branch]
    sort = -committerdate
[tag]
    sort = version:refname
[init]
    defaultBranch = main
[user]
    name = Dilawar Singh
    email = dilawar.s.rajput@gmail.com
[core]
	pager = delta
    fsmonitor = true
    untrackedCache = true
	autocrlf = input
[merge]
    tool = nvimdiff
	conflictStyle = zdiff3
[diff]
    algorithm = histogram
    colorMoved = plain
    mnemonicPrefix = true
    renames = true
    tool = nvimdiff
[alias]
    lol = log --all --decorate --oneline --graph
    lg1 = log --graph --abbrev-commit --decorate --all
    lg = !"git lg1"
[pull]
    rebase = true
[push]
    default = simple
    autoSetupRemote = true
    followTags = true
[fetch]
    prune = true
    pruneTags = true
    all = false

[credential "https://gitlab.dognosis.link"]
	helper = !/usr/bin/glab auth git-credential

[help]
    autocorrect = prompt
[commit]
    verbose = true
[rerere]
    enabled = true
    autoupdate = true
[rebase]
    autoSquash = true
    autoStash = true
    updateRefs = true
[checkout]
	defaultRemote = origin
[grep]
    lineNumber = true
[credential "https://gitlab.com"]
	helper = 
	helper = !/home/linuxbrew/.linuxbrew/Cellar/glab/1.91.0/bin/glab auth git-credential
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true
